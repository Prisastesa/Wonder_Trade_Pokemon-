# ================================
# 1. PREPARATION DES DONNEES
# ================================
library(dplyr)
library(ggplot2)
library(broom)
# Nettoyage variable cible (NA = neutre → supprimé)
trades$liked_clean <- ifelse(trades$liked == "like", 1,
ifelse(trades$liked == "dislike", 0, NA))
# Fusion des tables
df <- merge(trades, pokemon, by.x = "pokemonId", by.y = "pokedex_number")
# Suppression des NA
df <- na.omit(df)
# ================================
# 2. MODELE LOGISTIQUE
# ================================
model <- glm(liked_clean ~ level + hp + base_total + capture_rate +
hasItem + hasHiddenAbility + hasEggMove +
hasPerfectIV + hasPokerus + isShiny,
data = df,
family = binomial)
summary(model)
# Odds ratio (interprétation)
exp(coef(model))
# ================================
# 3. GRAPHIQUE 1 : COEFFICIENTS
# ================================
coef_df <- tidy(model, conf.int = TRUE)
# ================================
# 1. LIBRAIRIES
# ================================
library(dplyr)
library(nnet)
library(ggplot2)
library(broom)
# ================================
# 2. PREPARATION DES DONNEES
# ================================
# Créer variable à 3 modalités
trades$liked_multi <- ifelse(trades$liked == "like", "like",
ifelse(trades$liked == "dislike", "dislike", "neutral"))
# Fusion
data_etude <- merge(trades, pokemon, by.x = "pokemonId", by.y = "pokedex_number")
# Supprimer NA utiles uniquement (pas liked)
data_etude <- data_etude %>%
select(liked_multi, level, hp, capture_rate,
hasItem, hasHiddenAbility, hasEggMove) %>%
na.omit()
# Transformer en facteur
data_etude$liked_multi <- as.factor(data_etude$liked_multi)
# ================================
# 3. MODELE MULTINOMIAL
# ================================
modele_multi <- multinom(liked_multi ~ level + hasItem + hasHiddenAbility +
hasEggMove + hp + capture_rate,
data = data_etude)
summary(modele_multi)
# ================================
# 4. SIGNIFICATIVITE (important)
# ================================
z <- summary(modele_multi)$coefficients / summary(modele_multi)$standard.errors
p_values <- (1 - pnorm(abs(z), 0, 1)) * 2
p_values
# ================================
# 5. VISUALISATION DES COEFFICIENTS
# ================================
coef_df <- tidy(modele_multi)
ggplot(coef_df, aes(x = estimate, y = term)) +
geom_point(size = 3) +
facet_wrap(~ y.level) +
labs(
title = "Effet des variables sur les catégories de satisfaction",
x = "Coefficient",
y = "Variables"
) +
theme_minimal()
# ================================
# 6. PREDICTION VISUELLE (capture_rate)
# ================================
new_data <- data.frame(
capture_rate = seq(min(data_etude$capture_rate),
max(data_etude$capture_rate), length.out = 100),
level = mean(data_etude$level),
hp = mean(data_etude$hp),
hasItem = 0,
hasHiddenAbility = 0,
hasEggMove = 0
)
pred <- predict(modele_multi, newdata = new_data, type = "probs")
# 0. Vérification et installation automatique des packages
packages_requis <- c("nnet", "ggplot2", "broom")
packages_a_installer <- packages_requis[!(packages_requis %in% installed.packages()[,"Package"])]
if(length(packages_a_installer)) install.packages(packages_a_installer)
