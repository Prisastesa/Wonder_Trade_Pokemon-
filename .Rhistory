if(length(packages_a_installer)) install.packages(packages_a_installer)
# Chargement des librairies
library(nnet)
library(ggplot2)
library(broom)
# 1. Chargement et Fusion (à adapter avec tes chemins de fichiers si besoin)
trades <- read.csv("Trades.csv", sep = ";")
pokemon <- read.csv("pokemon.csv", sep = ",")
data_etude <- merge(trades, pokemon, by.x = "pokemonId", by.y = "pokedex_number")
# 2. GESTION DES NEUTRES : On remplace les vides par "neutral"
data_etude$liked[data_etude$liked == "" | is.na(data_etude$liked)] <- "neutral"
data_etude$liked <- as.factor(data_etude$liked)
data_etude$liked <- relevel(data_etude$liked, ref = "neutral")
# 3. CORRECTION DES VARIABLES NUMERIQUES
data_etude$capture_rate <- as.numeric(data_etude$capture_rate)
data_etude$hp <- as.numeric(data_etude$hp)
data_etude$base_total <- as.numeric(data_etude$base_total)
data_etude$level <- as.numeric(data_etude$level)
# 4. Le Modèle
modele_multi <- multinom(liked ~ level + hasItem + hasHiddenAbility +
hasPerfectIV + hasEggMove + hp + capture_rate,
data = data_etude)
# 5. Préparation des données pour le graphique
resultats_propres <- tidy(modele_multi, conf.int = TRUE)
resultats_propres <- subset(resultats_propres, term != "(Intercept)")
# 6. Création du Graphique ggplot2 (Version 2024 Sans Warning)
ggplot(resultats_propres, aes(x = estimate, y = term, color = y.level)) +
geom_point(size = 3) +
# Correction Warning 1 : Utilisation de geom_errorbar avec orientation
# On ne dit plus "errorbarh", on utilise "errorbar" et R comprend l'axe via aes(xmin/xmax)
geom_errorbar(aes(xmin = conf.low, xmax = conf.high), width = 0.2) +
# Correction Warning 2 : Utilisation de "linewidth" au lieu de "size" pour les lignes
geom_vline(xintercept = 0, linetype = "dashed", color = "red", linewidth = 1) +
facet_wrap(~ y.level) +
theme_minimal() +
scale_color_manual(values = c("like" = "#2ecc71", "neutral" = "#f39c12")) +
labs(title = "Facteurs influençant la satisfaction d'un échange",
subtitle = "Un point à droite de la ligne rouge indique un effet positif.",
x = "Effet (Coefficient)",
y = "Caractéristiques du Pokémon") +
theme(legend.position = "none")
# ==============================================================================
# 0. PRÉPARATION DE L'ENVIRONNEMENT
# ==============================================================================
packages_requis <- c("nnet", "ggplot2", "broom", "dplyr")
packages_a_installer <- packages_requis[!(packages_requis %in% installed.packages()[,"Package"])]
if(length(packages_a_installer)) install.packages(packages_a_installer)
library(nnet)
library(ggplot2)
library(broom)
library(dplyr)
# ==============================================================================
# 1. CHARGEMENT ET NETTOYAGE DES DONNÉES
# ==============================================================================
# Chargement des fichiers (vérifiez bien les séparateurs ";" ou ",")
trades <- read.csv("Trades.csv", sep = ";")
pokemon <- read.csv("pokemon.csv", sep = ",")
# Fusion des tables sur l'ID du Pokémon
data_etude <- merge(trades, pokemon, by.x = "pokemonId", by.y = "pokedex_number")
# Traitement de la variable cible 'liked' : on transforme les vides en "neutral"
data_etude$liked[data_etude$liked == "" | is.na(data_etude$liked)] <- "neutral"
data_etude$liked <- as.factor(data_etude$liked)
# On définit le 'dislike' comme la référence (le point 0 du graphique)
data_etude$liked <- relevel(data_etude$liked, ref = "dislike")
# Conversion forcée en numérique pour éviter les répétitions de variables (ex: capture_rate)
data_etude <- data_etude %>%
mutate(
capture_rate = as.numeric(as.character(capture_rate)),
hp = as.numeric(as.character(hp)),
base_total = as.numeric(as.character(base_total)),
level = as.numeric(as.character(level))
)
# ==============================================================================
# 2. MODÉLISATION (RÉGRESSION MULTINOMIALE)
# ==============================================================================
# On inclut les variables stratégiques et les statistiques de base
modele_multi <- multinom(liked ~ level + hasItem + hasHiddenAbility +
hasPerfectIV + hasEggMove + hp + capture_rate + base_total,
data = data_etude, trace = FALSE)
# Extraction des résultats propres avec intervalles de confiance
resultats_propres <- tidy(modele_multi, conf.int = TRUE)
# On filtre pour ne garder que les variables explicatives (on retire l'Intercept)
resultats_graphique <- resultats_propres %>% filter(term != "(Intercept)")
# ==============================================================================
# 3. VISUALISATION (FOREST PLOT OPTIMISÉ)
# ==============================================================================
ggplot(resultats_graphique, aes(x = estimate, y = term, color = y.level)) +
# Ligne de référence (Zéro = Dislike)
geom_vline(xintercept = 0, linetype = "dashed", color = "red", linewidth = 0.8) +
# Barres d'erreur (Intervalles de confiance)
geom_errorbar(aes(xmin = conf.low, xmax = conf.high), width = 0.3, linewidth = 0.8) +
# Points des coefficients
geom_point(size = 3.5) +
# Séparation Like / Neutral pour la clarté
facet_wrap(~ y.level) +
# Couleurs professionnelles
scale_color_manual(values = c("like" = "#00b894", "neutral" = "#0984e3")) +
theme_minimal(base_size = 13) +
labs(
title = "Facteurs influençant la satisfaction d'un échange",
subtitle = "Un point à droite de la ligne rouge indique un impact positif par rapport au 'dislike'",
x = "Force de l'effet (Coefficient)",
y = "Caractéristiques du Pokémon"
) +
theme(
legend.position = "none",
panel.grid.minor = element_blank(),
strip.text = element_text(face = "bold", size = 14)
)
# 0. Vérification et installation automatique des packages
packages_requis <- c("nnet", "ggplot2", "broom")
packages_a_installer <- packages_requis[!(packages_requis %in% installed.packages()[,"Package"])]
if(length(packages_a_installer)) install.packages(packages_a_installer)
